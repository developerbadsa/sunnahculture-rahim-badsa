{% doc %}
  @prompt
     Create a modern, clean Shopify header for an eCommerce electronics store.
    
    The header should include:
    
    Left side: Minimal logo (simple icon style)
    Center: Large search bar with placeholder text "Search"
    Right side:
    Customer support section with phone number (example: 1-800-123-45-67)
    User account icon
    Wishlist icon with notification badge
    Shopping cart icon with item count and subtotal price ($0.00)
    
    Below the main header, add a navigation menu with categories:
    
    Stores
    Watch (with "Sale" badge)
    Cellphones
    Accessories (with "Trending" badge)
    Laptops
    Support
    
    On the far right of the menu:
    
    "All sales" link
    "Shipping & Delivery" link
    
    Design style:
    
    Clean, modern, light background
    Subtle shadows
    Rounded search bar
    Minimal icons
    Professional eCommerce UI (similar to tech stores)
    📱 Mobile Responsive Instructions (IMPORTANT — include this in prompt)
    
    Add this section to ensure perfect mobile behavior:
    
    Make the header fully mobile responsive:
    
    Replace menu with hamburger menu on mobile
    Keep logo on left, icons on right
    Move search bar below header or use expandable search icon
    Stack elements cleanly with proper spacing
    Ensure icons are touch-friendly
    Keep cart and wishlist visible at all times
    Optimize for fast loading and clean UX, logo need center mobile view and menu need left also Navigation menu
     need seleted any menu from store so it show automtic, logo size need contorl also, cart and others button need wokring must  and everting need chan geble 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-ecom-header-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.header_bg_color }};
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .ai-ecom-header__top-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 24px;
    max-width: 1400px;
    margin: 0 auto;
    gap: 24px;
  }

  .ai-ecom-header__logo-{{ ai_gen_id }} {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .ai-ecom-header__logo-link-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
  }

  .ai-ecom-header__logo-{{ ai_gen_id }} img {
    max-width: {{ block.settings.logo_width }}px;
    height: auto;
    display: block;
  }

  .ai-ecom-header__logo-placeholder-{{ ai_gen_id }} {
    width: {{ block.settings.logo_width }}px;
    height: 50px;
    background-color: #f4f4f4;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-ecom-header__logo-placeholder-{{ ai_gen_id }} svg {
    width: 40px;
    height: 40px;
    opacity: 0.3;
  }

  .ai-ecom-header__search-{{ ai_gen_id }} {
    flex-grow: 1;
    max-width: 600px;
    position: relative;
  }

  .ai-ecom-header__search-form-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-ecom-header__search-input-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 48px 12px 20px;
    border: 1px solid {{ block.settings.search_border_color }};
    border-radius: {{ block.settings.search_border_radius }}px;
    font-size: 15px;
    background-color: {{ block.settings.search_bg_color }};
    color: {{ block.settings.text_color }};
    transition: all 0.3s ease;
  }

  .ai-ecom-header__search-input-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.primary_color }};
    box-shadow: 0 0 0 3px {{ block.settings.primary_color }}33;
  }

  .ai-ecom-header__search-btn-{{ ai_gen_id }} {
    position: absolute;
    right: 8px;
    top: 50%;
    transform: translateY(-50%);
    width: 36px;
    height: 36px;
    background: none;
    border: none;
    cursor: pointer;
    color: {{ block.settings.icon_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: background-color 0.3s ease;
  }

  .ai-ecom-header__search-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.primary_color }}22;
  }

  .ai-ecom-header__search-btn-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .ai-ecom-header__actions-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-shrink: 0;
  }

  .ai-ecom-header__support-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    color: {{ block.settings.text_color }};
    font-size: 14px;
  }

  .ai-ecom-header__support-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    color: {{ block.settings.icon_color }};
  }

  .ai-ecom-header__support-text-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    line-height: 1.3;
  }

  .ai-ecom-header__support-label-{{ ai_gen_id }} {
    font-size: 11px;
    opacity: 0.7;
  }

  .ai-ecom-header__support-phone-{{ ai_gen_id }} {
    font-weight: 600;
    color: {{ block.settings.text_color }};
  }

  .ai-ecom-header__icon-group-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .ai-ecom-header__icon-btn-{{ ai_gen_id }} {
    position: relative;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: {{ block.settings.icon_color }};
    transition: color 0.3s ease;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-ecom-header__icon-btn-{{ ai_gen_id }}:hover {
    color: {{ block.settings.primary_color }};
  }

  .ai-ecom-header__icon-btn-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
    display: block;
  }

  .ai-ecom-header__badge-{{ ai_gen_id }} {
    position: absolute;
    top: 2px;
    right: 2px;
    background-color: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    font-size: 10px;
    font-weight: 700;
    min-width: 18px;
    height: 18px;
    border-radius: 9px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 4px;
  }

  .ai-ecom-header__cart-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-ecom-header__cart-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    font-size: 12px;
    color: {{ block.settings.text_color }};
    line-height: 1.3;
  }

  .ai-ecom-header__cart-label-{{ ai_gen_id }} {
    opacity: 0.7;
  }

  .ai-ecom-header__cart-total-{{ ai_gen_id }} {
    font-weight: 700;
    font-size: 14px;
  }

  .ai-ecom-header__nav-{{ ai_gen_id }} {
    border-top: 1px solid {{ block.settings.nav_border_color }};
    background-color: {{ block.settings.nav_bg_color }};
  }

  .ai-ecom-header__nav-inner-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .ai-ecom-header__menu-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 32px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ai-ecom-header__menu-item-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-ecom-header__menu-link-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 16px 0;
    color: {{ block.settings.nav_text_color }};
    text-decoration: none;
    font-size: 15px;
    font-weight: 500;
    transition: color 0.3s ease;
  }

  .ai-ecom-header__menu-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.primary_color }};
  }

  .ai-ecom-header__menu-badge-{{ ai_gen_id }} {
    background-color: {{ block.settings.menu_badge_bg }};
    color: {{ block.settings.menu_badge_text }};
    font-size: 10px;
    font-weight: 700;
    padding: 2px 6px;
    border-radius: 4px;
    text-transform: uppercase;
  }

  .ai-ecom-header__secondary-links-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .ai-ecom-header__secondary-link-{{ ai_gen_id }} {
    color: {{ block.settings.nav_text_color }};
    text-decoration: none;
    font-size: 14px;
    transition: color 0.3s ease;
  }

  .ai-ecom-header__secondary-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.primary_color }};
  }

  .ai-ecom-header__mobile-toggle-{{ ai_gen_id }} {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: {{ block.settings.icon_color }};
  }

  .ai-ecom-header__mobile-toggle-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
    display: block;
  }

  .ai-ecom-header__mobile-search-{{ ai_gen_id }} {
    display: none;
    padding: 16px 24px;
    border-top: 1px solid {{ block.settings.nav_border_color }};
  }

  .ai-ecom-header__mobile-menu-{{ ai_gen_id }} {
    display: none;
    position: fixed;
    top: 0;
    left: -100%;
    width: 280px;
    height: 100vh;
    background-color: {{ block.settings.header_bg_color }};
    box-shadow: 2px 0 12px rgba(0, 0, 0, 0.15);
    transition: left 0.3s ease;
    z-index: 1000;
    overflow-y: auto;
  }

  .ai-ecom-header__mobile-menu-{{ ai_gen_id }}.active {
    left: 0;
  }

  .ai-ecom-header__mobile-menu-header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid {{ block.settings.nav_border_color }};
  }

  .ai-ecom-header__mobile-close-{{ ai_gen_id }} {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: {{ block.settings.icon_color }};
  }

  .ai-ecom-header__mobile-close-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  .ai-ecom-header__mobile-nav-{{ ai_gen_id }} {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ai-ecom-header__mobile-nav-item-{{ ai_gen_id }} {
    border-bottom: 1px solid {{ block.settings.nav_border_color }};
  }

  .ai-ecom-header__mobile-nav-link-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    color: {{ block.settings.text_color }};
    text-decoration: none;
    font-size: 15px;
  }

  .ai-ecom-header__mobile-nav-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_bg_color }};
  }

  .ai-ecom-header__overlay-{{ ai_gen_id }} {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 999;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .ai-ecom-header__overlay-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  @media screen and (max-width: 1024px) {
    .ai-ecom-header__support-{{ ai_gen_id }} {
      display: none;
    }

    .ai-ecom-header__actions-{{ ai_gen_id }} {
      gap: 16px;
    }

    .ai-ecom-header__icon-group-{{ ai_gen_id }} {
      gap: 12px;
    }

    .ai-ecom-header__menu-{{ ai_gen_id }} {
      gap: 20px;
    }
  }

  @media screen and (max-width: 768px) {
    .ai-ecom-header__top-{{ ai_gen_id }} {
      padding: 12px 16px;
      gap: 12px;
    }

    .ai-ecom-header__logo-{{ ai_gen_id }} {
      order: 2;
      flex-grow: 1;
      justify-content: center;
    }

    .ai-ecom-header__logo-{{ ai_gen_id }} img {
      max-width: {{ block.settings.mobile_logo_width }}px;
    }

    .ai-ecom-header__logo-placeholder-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_logo_width }}px;
      height: 40px;
    }

    .ai-ecom-header__mobile-toggle-{{ ai_gen_id }} {
      display: block;
      order: 1;
    }

    .ai-ecom-header__search-{{ ai_gen_id }} {
      display: none;
    }

    .ai-ecom-header__mobile-search-{{ ai_gen_id }} {
      display: block;
    }

    .ai-ecom-header__actions-{{ ai_gen_id }} {
      order: 3;
      gap: 8px;
    }

    .ai-ecom-header__cart-info-{{ ai_gen_id }} {
      display: none;
    }

    .ai-ecom-header__nav-{{ ai_gen_id }} {
      display: none;
    }

    .ai-ecom-header__mobile-menu-{{ ai_gen_id }} {
      display: block;
    }

    .ai-ecom-header__overlay-{{ ai_gen_id }} {
      display: block;
    }
  }
{% endstyle %}

<ecom-header-{{ ai_gen_id }} class="ai-ecom-header-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-ecom-header__top-{{ ai_gen_id }}">
    <button class="ai-ecom-header__mobile-toggle-{{ ai_gen_id }}" aria-label="Open menu">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>

    <div class="ai-ecom-header__logo-{{ ai_gen_id }}">
      <a href="/" class="ai-ecom-header__logo-link-{{ ai_gen_id }}">
        {% if block.settings.logo %}
          <img src="{{ block.settings.logo | image_url: width: 400 }}" alt="{{ shop.name }}" loading="eager">
        {% else %}
          <div class="ai-ecom-header__logo-placeholder-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M12 6v6l4 2"></path>
            </svg>
          </div>
        {% endif %}
      </a>
    </div>

    <div class="ai-ecom-header__search-{{ ai_gen_id }}">
      <form action="/search" method="get" class="ai-ecom-header__search-form-{{ ai_gen_id }}" role="search">
        <input 
          type="search" 
          name="q"
          class="ai-ecom-header__search-input-{{ ai_gen_id }}" 
          placeholder="{{ block.settings.search_placeholder }}"
          aria-label="Search products"
          value="{{ search.terms | escape }}"
        >
        <button type="submit" class="ai-ecom-header__search-btn-{{ ai_gen_id }}" aria-label="Search">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.35-4.35"></path>
          </svg>
        </button>
      </form>
    </div>

    <div class="ai-ecom-header__actions-{{ ai_gen_id }}">
      {% if block.settings.show_support %}
        <div class="ai-ecom-header__support-{{ ai_gen_id }}">
          <svg class="ai-ecom-header__support-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
          </svg>
          <div class="ai-ecom-header__support-text-{{ ai_gen_id }}">
            <span class="ai-ecom-header__support-label-{{ ai_gen_id }}">{{ block.settings.support_label }}</span>
            <span class="ai-ecom-header__support-phone-{{ ai_gen_id }}">{{ block.settings.support_phone }}</span>
          </div>
        </div>
      {% endif %}

      <div class="ai-ecom-header__icon-group-{{ ai_gen_id }}">
        {% if block.settings.show_account %}
          <a href="/account" class="ai-ecom-header__icon-btn-{{ ai_gen_id }}" aria-label="Account">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
          </a>
        {% endif %}

        {% if block.settings.show_wishlist %}
          <a href="{{ block.settings.wishlist_url }}" class="ai-ecom-header__icon-btn-{{ ai_gen_id }}" aria-label="Wishlist">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
            </svg>
            {% if block.settings.wishlist_count > 0 %}
              <span class="ai-ecom-header__badge-{{ ai_gen_id }}">{{ block.settings.wishlist_count }}</span>
            {% endif %}
          </a>
        {% endif %}

        <div class="ai-ecom-header__cart-wrapper-{{ ai_gen_id }}">
          <a href="/cart" class="ai-ecom-header__icon-btn-{{ ai_gen_id }}" aria-label="Shopping cart">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="9" cy="21" r="1"></circle>
              <circle cx="20" cy="21" r="1"></circle>
              <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
            </svg>
            {% if cart.item_count > 0 %}
              <span class="ai-ecom-header__badge-{{ ai_gen_id }}">{{ cart.item_count }}</span>
            {% endif %}
          </a>

          <div class="ai-ecom-header__cart-info-{{ ai_gen_id }}">
            <span class="ai-ecom-header__cart-label-{{ ai_gen_id }}">{{ block.settings.cart_label }}</span>
            <span class="ai-ecom-header__cart-total-{{ ai_gen_id }}">{{ cart.total_price | money }}</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="ai-ecom-header__mobile-search-{{ ai_gen_id }}">
    <div class="ai-ecom-header__search-{{ ai_gen_id }}">
      <form action="/search" method="get" class="ai-ecom-header__search-form-{{ ai_gen_id }}" role="search">
        <input 
          type="search" 
          name="q"
          class="ai-ecom-header__search-input-{{ ai_gen_id }}" 
          placeholder="{{ block.settings.search_placeholder }}"
          aria-label="Search products"
          value="{{ search.terms | escape }}"
        >
        <button type="submit" class="ai-ecom-header__search-btn-{{ ai_gen_id }}" aria-label="Search">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.35-4.35"></path>
          </svg>
        </button>
      </form>
    </div>
  </div>

  <nav class="ai-ecom-header__nav-{{ ai_gen_id }}">
    <div class="ai-ecom-header__nav-inner-{{ ai_gen_id }}">
      <ul class="ai-ecom-header__menu-{{ ai_gen_id }}">
        {% if block.settings.menu != blank %}
          {% for link in block.settings.menu.links %}
            <li class="ai-ecom-header__menu-item-{{ ai_gen_id }}">
              <a href="{{ link.url }}" class="ai-ecom-header__menu-link-{{ ai_gen_id }}">
                {{ link.title }}
                {% if link.title == block.settings.sale_menu_item %}
                  <span class="ai-ecom-header__menu-badge-{{ ai_gen_id }}">Sale</span>
                {% endif %}
                {% if link.title == block.settings.trending_menu_item %}
                  <span class="ai-ecom-header__menu-badge-{{ ai_gen_id }}">Trending</span>
                {% endif %}
              </a>
            </li>
          {% endfor %}
        {% else %}
          <li class="ai-ecom-header__menu-item-{{ ai_gen_id }}">
            <a href="/collections" class="ai-ecom-header__menu-link-{{ ai_gen_id }}">Stores</a>
          </li>
          <li class="ai-ecom-header__menu-item-{{ ai_gen_id }}">
            <a href="/collections/watch" class="ai-ecom-header__menu-link-{{ ai_gen_id }}">
              Watch
              <span class="ai-ecom-header__menu-badge-{{ ai_gen_id }}">Sale</span>
            </a>
          </li>
          <li class="ai-ecom-header__menu-item-{{ ai_gen_id }}">
            <a href="/collections/cellphones" class="ai-ecom-header__menu-link-{{ ai_gen_id }}">Cellphones</a>
          </li>
          <li class="ai-ecom-header__menu-item-{{ ai_gen_id }}">
            <a href="/collections/accessories" class="ai-ecom-header__menu-link-{{ ai_gen_id }}">
              Accessories
              <span class="ai-ecom-header__menu-badge-{{ ai_gen_id }}">Trending</span>
            </a>
          </li>
          <li class="ai-ecom-header__menu-item-{{ ai_gen_id }}">
            <a href="/collections/laptops" class="ai-ecom-header__menu-link-{{ ai_gen_id }}">Laptops</a>
          </li>
          <li class="ai-ecom-header__menu-item-{{ ai_gen_id }}">
            <a href="/pages/support" class="ai-ecom-header__menu-link-{{ ai_gen_id }}">Support</a>
          </li>
        {% endif %}
      </ul>

      <div class="ai-ecom-header__secondary-links-{{ ai_gen_id }}">
        {% if block.settings.show_sales_link %}
          <a href="{{ block.settings.sales_link_url }}" class="ai-ecom-header__secondary-link-{{ ai_gen_id }}">
            {{ block.settings.sales_link_text }}
          </a>
        {% endif %}
        {% if block.settings.show_shipping_link %}
          <a href="{{ block.settings.shipping_link_url }}" class="ai-ecom-header__secondary-link-{{ ai_gen_id }}">
            {{ block.settings.shipping_link_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </nav>

  <div class="ai-ecom-header__overlay-{{ ai_gen_id }}"></div>

  <div class="ai-ecom-header__mobile-menu-{{ ai_gen_id }}">
    <div class="ai-ecom-header__mobile-menu-header-{{ ai_gen_id }}">
      <div class="ai-ecom-header__logo-{{ ai_gen_id }}">
        {% if block.settings.logo %}
          <img src="{{ block.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" loading="eager">
        {% else %}
          <div class="ai-ecom-header__logo-placeholder-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M12 6v6l4 2"></path>
            </svg>
          </div>
        {% endif %}
      </div>
      <button class="ai-ecom-header__mobile-close-{{ ai_gen_id }}" aria-label="Close menu">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <ul class="ai-ecom-header__mobile-nav-{{ ai_gen_id }}">
      {% if block.settings.menu != blank %}
        {% for link in block.settings.menu.links %}
          <li class="ai-ecom-header__mobile-nav-item-{{ ai_gen_id }}">
            <a href="{{ link.url }}" class="ai-ecom-header__mobile-nav-link-{{ ai_gen_id }}">
              {{ link.title }}
              {% if link.title == block.settings.sale_menu_item %}
                <span class="ai-ecom-header__menu-badge-{{ ai_gen_id }}">Sale</span>
              {% endif %}
              {% if link.title == block.settings.trending_menu_item %}
                <span class="ai-ecom-header__menu-badge-{{ ai_gen_id }}">Trending</span>
              {% endif %}
            </a>
          </li>
        {% endfor %}
      {% else %}
        <li class="ai-ecom-header__mobile-nav-item-{{ ai_gen_id }}">
          <a href="/collections" class="ai-ecom-header__mobile-nav-link-{{ ai_gen_id }}">Stores</a>
        </li>
        <li class="ai-ecom-header__mobile-nav-item-{{ ai_gen_id }}">
          <a href="/collections/watch" class="ai-ecom-header__mobile-nav-link-{{ ai_gen_id }}">
            Watch
            <span class="ai-ecom-header__menu-badge-{{ ai_gen_id }}">Sale</span>
          </a>
        </li>
        <li class="ai-ecom-header__mobile-nav-item-{{ ai_gen_id }}">
          <a href="/collections/cellphones" class="ai-ecom-header__mobile-nav-link-{{ ai_gen_id }}">Cellphones</a>
        </li>
        <li class="ai-ecom-header__mobile-nav-item-{{ ai_gen_id }}">
          <a href="/collections/accessories" class="ai-ecom-header__mobile-nav-link-{{ ai_gen_id }}">
            Accessories
            <span class="ai-ecom-header__menu-badge-{{ ai_gen_id }}">Trending</span>
          </a>
        </li>
        <li class="ai-ecom-header__mobile-nav-item-{{ ai_gen_id }}">
          <a href="/collections/laptops" class="ai-ecom-header__mobile-nav-link-{{ ai_gen_id }}">Laptops</a>
        </li>
        <li class="ai-ecom-header__mobile-nav-item-{{ ai_gen_id }}">
          <a href="/pages/support" class="ai-ecom-header__mobile-nav-link-{{ ai_gen_id }}">Support</a>
        </li>
      {% endif %}

      {% if block.settings.show_sales_link %}
        <li class="ai-ecom-header__mobile-nav-item-{{ ai_gen_id }}">
          <a href="{{ block.settings.sales_link_url }}" class="ai-ecom-header__mobile-nav-link-{{ ai_gen_id }}">
            {{ block.settings.sales_link_text }}
          </a>
        </li>
      {% endif %}
      {% if block.settings.show_shipping_link %}
        <li class="ai-ecom-header__mobile-nav-item-{{ ai_gen_id }}">
          <a href="{{ block.settings.shipping_link_url }}" class="ai-ecom-header__mobile-nav-link-{{ ai_gen_id }}">
            {{ block.settings.shipping_link_text }}
          </a>
        </li>
      {% endif %}
    </ul>
  </div>
</ecom-header-{{ ai_gen_id }}>

<script>
  (function() {
    class EcomHeader{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.mobileToggle = this.querySelector('.ai-ecom-header__mobile-toggle-{{ ai_gen_id }}');
        this.mobileMenu = this.querySelector('.ai-ecom-header__mobile-menu-{{ ai_gen_id }}');
        this.mobileClose = this.querySelector('.ai-ecom-header__mobile-close-{{ ai_gen_id }}');
        this.overlay = this.querySelector('.ai-ecom-header__overlay-{{ ai_gen_id }}');

        this.setupEventListeners();
      }

      setupEventListeners() {
        if (this.mobileToggle) {
          this.mobileToggle.addEventListener('click', () => this.openMobileMenu());
        }

        if (this.mobileClose) {
          this.mobileClose.addEventListener('click', () => this.closeMobileMenu());
        }

        if (this.overlay) {
          this.overlay.addEventListener('click', () => this.closeMobileMenu());
        }
      }

      openMobileMenu() {
        if (this.mobileMenu && this.overlay) {
          this.mobileMenu.classList.add('active');
          this.overlay.classList.add('active');
          document.body.style.overflow = 'hidden';
        }
      }

      closeMobileMenu() {
        if (this.mobileMenu && this.overlay) {
          this.mobileMenu.classList.remove('active');
          this.overlay.classList.remove('active');
          document.body.style.overflow = '';
        }
      }
    }

    customElements.define('ecom-header-{{ ai_gen_id }}', EcomHeader{{ ai_gen_id }});
  })();
</script>

