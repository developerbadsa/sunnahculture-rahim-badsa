    },
    {
      "type": "range",
      "id": "category_padding_vertical",
      "label": "Vertical padding",
      "min": 4,
      "max": 12,
      "step": 1,
      "unit": "px",
      "default": 6
    },
    {
      "type": "range",
      "id": "category_padding_horizontal",
      "label": "Horizontal padding",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
