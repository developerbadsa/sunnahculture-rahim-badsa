      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "divider_thickness",
      "label": "Divider thickness",
      "min": 1,
      "max": 5,
      "step": 1,
      "unit": "px",
