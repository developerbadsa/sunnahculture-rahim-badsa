    {
      "type": "header",
      "content": "Navigation menu"
    },
    {
      "type": "text",
      "id": "menu_item_1",
      "label": "Menu item 1",
      "default": "Stores"
    },
    {
      "type": "url",
      "id": "menu_link_1",
      "label": "Menu link 1"
    },
    {
      "type": "text",
      "id": "menu_item_2",
      "label": "Menu item 2",
      "default": "Watch"
    },
    {
      "type": "url",
      "id": "menu_link_2",
      "label": "Menu link 2"
    },
    {
      "type": "text",
      "id": "menu_2_badge",
      "label": "Menu 2 badge",
      "default": "Sale"
    },
    {
      "type": "text",
      "id": "menu_item_3",
      "label": "Menu item 3",
      "default": "Cellphones"
    },
    {
      "type": "url",
      "id": "menu_link_3",
      "label": "Menu link 3"
    },
    {
      "type": "text",
      "id": "menu_item_4",
      "label": "Menu item 4",
      "default": "Accessories"
    },
    {
      "type": "url",
      "id": "menu_link_4",
