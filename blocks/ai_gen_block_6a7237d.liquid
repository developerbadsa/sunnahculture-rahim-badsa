      "default": true
    },
    {
      "type": "text",
      "id": "support_label",
      "label": "Support label",
      "default": "Customer support"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone number",
      "default": "1-800-123-45-67"
    },
    {
      "type": "header",
      "content": "Icons"
    },
