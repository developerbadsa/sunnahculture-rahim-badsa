{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-banner-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    min-height: {{ block.settings.banner_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
    margin-left: auto;
    margin-right: auto;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_left }}px;
    padding-right: {{ block.settings.padding_right }}px;
  }

  .ai-collection-banner__background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-collection-banner__background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-collection-banner__background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-collection-banner__background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-collection-banner__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 2;
  }

  .ai-collection-banner__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    text-align: center;
    padding: {{ block.settings.content_padding }}px;
    max-width: {{ block.settings.content_max_width }}px;
    width: 100%;
  }

  .ai-collection-banner__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size_desktop }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px 0;
    font-weight: {{ block.settings.title_weight }};
    line-height: 1.2;
    letter-spacing: {{ block.settings.title_letter_spacing }}px;
  }

  .ai-collection-banner__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size_desktop }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-collection-banner__description-{{ ai_gen_id }} p {
    margin: 0 0 16px 0;
  }

  .ai-collection-banner__description-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-banner-{{ ai_gen_id }} {
      min-height: {{ block.settings.mobile_banner_height }}px;
      margin-top: {{ block.settings.mobile_margin_top }}px;
      margin-bottom: {{ block.settings.mobile_margin_bottom }}px;
      padding-top: {{ block.settings.mobile_padding_top }}px;
      padding-bottom: {{ block.settings.mobile_padding_bottom }}px;
      padding-left: {{ block.settings.mobile_padding_left }}px;
      padding-right: {{ block.settings.mobile_padding_right }}px;
    }

    .ai-collection-banner__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_mobile }}px;
    }

    .ai-collection-banner__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size_mobile }}px;
    }

    .ai-collection-banner__content-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding | times: 0.6 }}px;
    }
  }
{% endstyle %}

<div class="ai-collection-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-collection-banner__background-{{ ai_gen_id }}">
    {% if collection.image %}
      <img
        src="{{ collection.image | image_url: width: 2000 }}"
        alt="{{ collection.image.alt | escape }}"
        loading="lazy"
        width="{{ collection.image.width }}"
        height="{{ collection.image.height }}"
      >
    {% elsif collection.products.first.featured_image %}
      <img
        src="{{ collection.products.first.featured_image | image_url: width: 2000 }}"
        alt="{{ collection.products.first.featured_image.alt | escape }}"
        loading="lazy"
        width="{{ collection.products.first.featured_image.width }}"
        height="{{ collection.products.first.featured_image.height }}"
      >
    {% else %}
      <div class="ai-collection-banner__background-placeholder-{{ ai_gen_id }}">
        {{ 'collection-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="ai-collection-banner__overlay-{{ ai_gen_id }}"></div>

  <div class="ai-collection-banner__content-{{ ai_gen_id }}">
    {% if block.settings.show_title %}
      <h1 class="ai-collection-banner__title-{{ ai_gen_id }}">
        {{ collection.title }}
      </h1>
    {% endif %}

    {% if block.settings.show_description and collection.description != blank %}
      <div class="ai-collection-banner__description-{{ ai_gen_id }}">
        {{ collection.description }}
      </div>
    {% endif %}
  </div>
</div>

