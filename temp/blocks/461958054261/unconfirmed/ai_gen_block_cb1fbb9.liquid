            {% if block.settings.menu_2_badge != blank %}
              <span class="ai-header-nav-badge-{{ ai_gen_id }}">{{ block.settings.menu_2_badge }}</span>
            {% endif %}
          </a>
        </li>
      {% endif %}

      {% if block.settings.menu_3 != blank %}
        <li class="ai-header-mobile-nav-item-{{ ai_gen_id }}">
          <a href="{{ block.settings.menu_3_link }}" class="ai-header-mobile-nav-link-{{ ai_gen_id }}">
            {{ block.settings.menu_3_text }}
          </a>
        </li>
      {% endif %}

      {% if block.settings.menu_4 != blank %}
        <li class="ai-header-mobile-nav-item-{{ ai_gen_id }}">
          <a href="{{ block.settings.menu_4_link }}" class="ai-header-mobile-nav-link-{{ ai_gen_id }}">
            {{ block.settings.menu_4_text }}
            {% if block.settings.menu_4_badge != blank %}
              <span class="ai-header-nav-badge-{{ ai_gen_id }}">{{ block.settings.menu_4_badge }}</span>
            {% endif %}
          </a>
        </li>
      {% endif %}

      {% if block.settings.menu_5 != blank %}
        <li class="ai-header-mobile-nav-item-{{ ai_gen_id }}">
          <a href="{{ block.settings.menu_5_link }}" class="ai-header-mobile-nav-link-{{ ai_gen_id }}">
            {{ block.settings.menu_5_text }}
          </a>
        </li>
      {% endif %}

      {% if block.settings.menu_6 != blank %}
        <li class="ai-header-mobile-nav-item-{{ ai_gen_id }}">
          <a href="{{ block.settings.menu_6_link }}" class="ai-header-mobile-nav-link-{{ ai_gen_id }}">
            {{ block.settings.menu_6_text }}
          </a>
        </li>
      {% endif %}

      {% if block.settings.collection_menu != blank %}
        <li class="ai-header-mobile-nav-item-{{ ai_gen_id }}">
          <button class="ai-header-mobile-nav-link-{{ ai_gen_id }}" data-submenu-toggle>
            {{ block.settings.collection_menu.title }}
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          {% if block.settings.collection_menu.links.size > 0 %}
            <ul class="ai-header-mobile-submenu-{{ ai_gen_id }}">
              {% for link in block.settings.collection_menu.links %}
                <li>
                  <a href="{{ link.url }}" class="ai-header-mobile-submenu-link-{{ ai_gen_id }}">
                    {{ link.title }}
                  </a>
                </li>
              {% endfor %}
